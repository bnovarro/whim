# ─── Copy this file to .env and fill in real values ─────────────────────────
# .env is gitignored — never commit it.

# ── Supabase (Project Settings → API) ───────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Google OAuth (Cloud Console → APIs & Services → Credentials) ─────────────
# Web client → used by Supabase signInWithIdToken + Expo Go testing
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# iOS client → bundle ID: com.whim.app
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# Android client → package: com.whim.app
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# ── Third-party APIs ─────────────────────────────────────────────────────────
EXPO_PUBLIC_WEATHER_API_KEY=your_openweathermap_api_key_here
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
EXPO_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_api_key_here
EXPO_PUBLIC_YELP_API_KEY=your_yelp_api_key_here
